NODE_ENV=development
HOST=127.0.0.1
PORT=3100

ALLOWED_CALLER_IPS=127.0.0.1,192.168.112.11
SERVICE_AUTH_KEYS_JSON={"pvs-web2":"replace-with-a-strong-secret-at-least-32-characters"}
SERVICE_AUTH_MAX_CLOCK_SKEW_SECONDS=120
SERVICE_AUTH_NONCE_TTL_SECONDS=300
SERVICE_AUTH_MAX_NONCES=10000

DB_DSN=WebData
DB_UID=DocumentApiService
DB_PWD=replace-with-password
DB_LOGIN_TIMEOUT_SECONDS=15
DB_CONNECTION_TIMEOUT_SECONDS=60
DB_QUERY_TIMEOUT_SECONDS=60
DB_POOL_ENABLED=true
DB_POOL_INITIAL_SIZE=1
DB_POOL_INCREMENT_SIZE=1
DB_POOL_MAX_SIZE=3
DB_CONNECTION_AUTHENTICATION=

# AI_SUMMARY_DOCUMENT_LINK_PATCH_V1
# Normal PVS document root. New AI summaries are written to the database-approved
# client path under Clients\<client>\AI Summaries.
DOCUMENT_SOURCE_ROOT=\\fs2\public\PTS Share
# Legacy generated-report location. Keep until older WebAISummary rows are migrated.
GENERATED_REPORT_ROOT=\\fs2\public\PTS Share\Client Services\AI Summaries
DOCUMENT_TEMP_ROOT=./temp

ZIP_CONCURRENCY=1
ZIP_MAX_QUEUE_LENGTH=5
ZIP_QUEUE_TIMEOUT_MS=30000
ZIP_IDLE_TIMEOUT_MS=120000
ZIP_MIN_FREE_DISK_BYTES=5368709120
ZIP_QUERY_PAGE_SIZE=100

GENERATED_REPORT_MAX_BYTES=26214400
SHUTDOWN_TIMEOUT_MS=30000
STALE_TEMP_MAX_AGE_HOURS=24
LOG_LEVEL=info

# Phase 6: encrypted per-request SQL Anywhere user context
DELEGATED_DB_CONTEXT_ENABLED=true
# Generate once: [Convert]::ToBase64String([byte[]](1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
DELEGATED_DB_CONTEXT_KEY=
DELEGATED_DB_CONTEXT_MAX_TTL_SECONDS=120
DELEGATED_DB_CONTEXT_MAX_CLOCK_SKEW_SECONDS=30
DB_USER_POOL_MAX_CREDENTIAL_POOLS=20
DB_USER_POOL_IDLE_TIMEOUT_MS=300000
